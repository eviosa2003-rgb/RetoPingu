<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!-- CORRECCIÓN 1: Los enlaces xmlns y xmlns:fx ahora son los correctos -->
<BorderPane styleClass="root" stylesheets="@PantallaJuego.css" 
            xmlns="http://javafx.com" 
            xmlns:fx="http://javafx.com" 
            fx:controller="vista.PantallaJuego">
    <top>
        <MenuBar>
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem fx:id="newGame" mnemonicParsing="false" onAction="#handleNewGame" text="New" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="saveGame" mnemonicParsing="false" onAction="#handleSaveGame" text="Save" />
                        <MenuItem fx:id="loadGame" mnemonicParsing="false" onAction="#handleLoadGame" text="Load" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="quitGame" mnemonicParsing="false" onAction="#handleQuitGame" text="Quit" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <StackPane>
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <GridPane fx:id="tablero" prefHeight="520.0" styleClass="board">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="20.0" />
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="20.0" />
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="20.0" />
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="20.0" />
                    <ColumnConstraints hgrow="SOMETIMES" percentWidth="20.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints percentHeight="10.0" vgrow="SOMETIMES" /><RowConstraints percentHeight="10.0" vgrow="SOMETIMES" />
                    <RowConstraints percentHeight="10.0" vgrow="SOMETIMES" /><RowConstraints percentHeight="10.0" vgrow="SOMETIMES" />
                    <RowConstraints percentHeight="10.0" vgrow="SOMETIMES" /><RowConstraints percentHeight="10.0" vgrow="SOMETIMES" />
                    <RowConstraints percentHeight="10.0" vgrow="SOMETIMES" /><RowConstraints percentHeight="10.0" vgrow="SOMETIMES" />
                    <RowConstraints percentHeight="10.0" vgrow="SOMETIMES" /><RowConstraints percentHeight="10.0" vgrow="SOMETIMES" />
                </rowConstraints>
                <children>
                    <Text styleClass="cell-title" text="Start" GridPane.halignment="LEFT" GridPane.valignment="TOP" />
                    <Text styleClass="cell-title" text="Finish" GridPane.columnIndex="4" GridPane.halignment="RIGHT" GridPane.rowIndex="9" GridPane.valignment="BOTTOM" />

                    <!-- CORRECCIÓN 2: ImageViews sin la etiqueta <image> interna para evitar errores de ruta en el XML -->
                    <ImageView fx:id="P1" fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true" />
                    <ImageView fx:id="P2" fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true" />
                    <ImageView fx:id="P3" fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true" />
                    <ImageView fx:id="P4" fitHeight="55.0" fitWidth="55.0" pickOnBounds="true" preserveRatio="true" />
                </children>
            </GridPane>
        </StackPane>
    </center>

    <bottom>
        <HBox spacing="16" styleClass="bottom-bar">
            <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
            <VBox prefWidth="280" spacing="10" styleClass="card">
                <Label styleClass="card-title" text="Dado" />
                <Text fx:id="dadoResultText" styleClass="big-text" text="-" wrappingWidth="240" />
                <Button fx:id="dado" maxWidth="Infinity" onAction="#handleDado" styleClass="primary" text="Tirar dado" />
            </VBox>
            <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                <Label styleClass="card-title" text="Objetos" />
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                    <content>
                        <VBox spacing="10">
                            <padding><Insets bottom="6" left="6" right="6" top="6" /></padding>
                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                                <Text fx:id="peces_t" styleClass="stat" text="Peces: 0" />
                                <Region HBox.hgrow="ALWAYS" /><Button fx:id="peces" onAction="#handlePeces" text="Usar" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                                <Text fx:id="nieve_t" styleClass="stat" text="Bolas: 0" />
                                <Region HBox.hgrow="ALWAYS" /><Button fx:id="nieve" onAction="#handleNieve" text="Usar" />
                            </HBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>
            <VBox prefWidth="320" spacing="10" styleClass="card">
                <Label styleClass="card-title" text="Eventos" />
                <Text fx:id="eventos" styleClass="events" text="Esperando..." wrappingWidth="280" />
            </VBox>
        </HBox>
    </bottom>
</BorderPane>
