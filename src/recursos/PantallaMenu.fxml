<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Ellipse?>
<?import javafx.scene.shape.Polygon?>
<?import javafx.scene.shape.Rectangle?>


<BorderPane
    xmlns="http://javafx.com/javafx/21.0.10"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="vista.PantallaMenu"
    stylesheets="@PantallaMenu.css"
    styleClass="root"
    prefWidth="680" prefHeight="430">

    <!-- ═══════════════════════════════════════
         TOP: MenuBar
    ═══════════════════════════════════════ -->
    <top>
        <MenuBar styleClass="menu-bar">
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem fx:id="newGame"  mnemonicParsing="false" text="New"  onAction="#handleNewGame"/>
                        <SeparatorMenuItem mnemonicParsing="false"/>
                        <MenuItem fx:id="saveGame" mnemonicParsing="false" text="Save" onAction="#handleSaveGame"/>
                        <MenuItem fx:id="loadGame" mnemonicParsing="false" text="Load" onAction="#handleLoadGame"/>
                        <SeparatorMenuItem mnemonicParsing="false"/>
                        <MenuItem fx:id="quitGame" mnemonicParsing="false" text="Quit" onAction="#handleQuitGame"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <!-- ═══════════════════════════════════════
         CENTER: Fons + UI
    ═══════════════════════════════════════ -->
    <center>
        <StackPane>

            <!-- ─────────────────────────────
                 CAPA 0: Fons àrtic
                 El controlador pinta aquí el
                 paisatge (Canvas o ImageView).
                 Afegeix la imatge exportada
                 com a fons_arctic.png als recursos
                 i substitueix el Pane per:
                   <ImageView fx:id="fondoImg"
                     image="@fons_arctic.png"
                     fitWidth="680" fitHeight="430"
                     preserveRatio="false"/>
            ───────────────────────────── -->
           <ImageView
    fx:id="fondoImg"
    fitWidth="740" fitHeight="460"
    preserveRatio="false">
    <image>
        <Image url="@fons_arctic.png"/>
    </image>
</ImageView>

            <!-- ─────────────────────────────
                 CAPA 1: UI principal
            ───────────────────────────── -->
            <BorderPane>
                <padding>
                    <Insets top="10" right="14" bottom="10" left="14"/>
                </padding>

                <!-- TOP UI: Targeta jugador (esquerra) + Icones (dreta) -->
                <top>
                    <HBox alignment="CENTER_LEFT" spacing="0">

                        <!-- Targeta jugador -->
                        <HBox fx:id="jugadorCard" styleClass="jugador-card"
                              alignment="CENTER_LEFT" spacing="10">
                            <padding>
                                <Insets top="8" right="14" bottom="8" left="10"/>
                            </padding>
                            <!-- Icona pingüí (substitueix per ImageView si tens l'asset) -->
                            <Pane fx:id="jugadorIcon" styleClass="jugador-icon"
                                  prefWidth="42" prefHeight="42"/>
                            <VBox spacing="2" alignment="CENTER_LEFT">
                                <Label fx:id="jugadorNom" text="JUGADOR 1"
                                       styleClass="jugador-nom"/>
                                <HBox spacing="4" alignment="CENTER_LEFT">
                                    <Label text="★" styleClass="star-label"/>
                                    <Label fx:id="jugadorPunts" text="1250"
                                           styleClass="jugador-punts"/>
                                </HBox>
                            </VBox>
                        </HBox>

                        <!-- Espai flexible -->
                        <Region HBox.hgrow="ALWAYS"/>

                        <!-- Botons icones dalt-dreta -->
                        <HBox spacing="8" alignment="CENTER">
                            <Button fx:id="btnTrofeu"  text="🏆" styleClass="icon-btn"
                                    onAction="#handleTrofeu"/>
                            <Button fx:id="btnOpcions" text="⚙" styleClass="icon-btn"
                                    onAction="#handleOpcions"/>
                            <Button fx:id="btnAjuda"   text="?" styleClass="icon-btn"
                                    onAction="#handleAjuda"/>
                        </HBox>

                    </HBox>
                </top>

                <!-- CENTER UI: Títol (invisible, pintat al fons) + Botons centrats -->
                <center>
                    <HBox alignment="CENTER" spacing="40">

                        <!-- Columna botons principals -->
                        <VBox spacing="12" alignment="CENTER" prefWidth="220">

                            <!-- JUGAR — botó verd gran -->
                            <Button fx:id="btnJugar" text="▶  JUGAR"
                                    styleClass="btn-jugar" maxWidth="Infinity"
                                    onAction="#handleJugar"/>

                            <!-- PERSONATGES -->
                            <Button fx:id="btnPersonatges" text="PERSONATGES"
                                    styleClass="btn-menu" maxWidth="Infinity"
                                    onAction="#handlePersonatges"/>

                            <!-- RÀNQUING -->
                            <Button fx:id="btnRanquing" text="RÀNQUING"
                                    styleClass="btn-menu" maxWidth="Infinity"
                                    onAction="#handleRanquing"/>

                            <!-- BOTIGA -->
                            <Button fx:id="btnBotiga" text="BOTIGA"
                                    styleClass="btn-menu" maxWidth="Infinity"
                                    onAction="#handleBotiga"/>

                        </VBox>

                        <!-- Cartellet eslògan (dreta dels botons) -->
                        <VBox fx:id="cartellet" styleClass="cartellet"
                              alignment="CENTER" prefWidth="160">
                            <padding>
                                <Insets top="18" right="16" bottom="18" left="16"/>
                            </padding>
                            <Label text="CORRE, SALTA" styleClass="cartellet-text" wrapText="true"/>
                            <Label text="I ACONSEGUEIX" styleClass="cartellet-text" wrapText="true"/>
                            <Label text="LA MILLOR" styleClass="cartellet-text" wrapText="true"/>
                            <Label text="PUNTUACIÓ!" styleClass="cartellet-text" wrapText="true"/>
                        </VBox>

                    </HBox>
                </center>

                <!-- BOTTOM UI: Versió + Botó compartir -->
                <bottom>
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Button fx:id="btnCompartir" text="↑" styleClass="icon-btn"
                                onAction="#handleCompartir"/>
                        <Label fx:id="labelVersio" text="V1.0"
                               styleClass="versio-label"/>
                    </HBox>
                </bottom>

            </BorderPane>
        </StackPane>
    </center>

</BorderPane>
